{
  "name": "@fourcorners/canvas",
  "version": "0.1.0",
  "description": "Open canvas library for visual creation and structured metadata output. Built on Konva.js.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.mjs",
      "require": "./dist/react.js"
    },
    "./theme": {
      "types": "./dist/theme.d.ts",
      "import": "./dist/theme.mjs",
      "require": "./dist/theme.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "prepare": "npm run build",
    "build": "tsup && node scripts/postbuild.mjs",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "dependencies": {
    "konva": "~9.3.22",
    "react-konva": "~19.0.3",
    "react-konva-utils": "~1.1.3"
  },
  "devDependencies": {
    "@storybook/addon-essentials": "~8.6.14",
    "@storybook/blocks": "~8.6.14",
    "@storybook/react": "~8.6.14",
    "@storybook/react-vite": "~8.6.14",
    "@storybook/test": "~8.6.14",
    "@testing-library/react": "~16.3.0",
    "@types/react": "~19.1.0",
    "@types/react-dom": "~19.1.0",
    "canvas": "~3.1.0",
    "eslint": "~9.27.0",
    "jsdom": "~26.1.0",
    "react": "~19.1.0",
    "react-dom": "~19.1.0",
    "storybook": "~8.6.14",
    "tsup": "~8.4.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "~8.30.0",
    "vite": "~6.4.1",
    "vitest": "~3.1.2"
  },
  "keywords": [
    "canvas",
    "konva",
    "react",
    "visual-editor",
    "metadata",
    "four-corners",
    "photography",
    "nonfiction"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/fourcorners/canvas.git"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
